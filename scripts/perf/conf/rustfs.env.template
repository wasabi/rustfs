# RustFS environment template — expanded by lib/deploy.sh at run time.
#
# Placeholders (@@NAME@@) are substituted by deploy.sh using sed; all other
# lines are written verbatim to the env file on every node.

# ---------------------------------------------------------------------------
# Per-run placeholders (expanded by deploy.sh)
# ---------------------------------------------------------------------------

# Full volumes string for this topology — comes from RUSTFS_VOLUMES in paths.env.
RUSTFS_VOLUMES=@@RUSTFS_VOLUMES@@

# Preflight variant: always | auto | never — set by --variant flag.
RUSTFS_PUTOBJECT_EXISTING_OBJECT_LOCK_PREFLIGHT=@@PREFLIGHT_VARIANT@@

# Log level: "error" normally; replaced with the debug recipe when --trace is set.
RUST_LOG=@@RUST_LOG@@

# ---------------------------------------------------------------------------
# Credentials (lab-only values; safe for this repo)
# ---------------------------------------------------------------------------

RUSTFS_ACCESS_KEY=wasabitest123456
RUSTFS_SECRET_KEY=wasabitest123456

# ---------------------------------------------------------------------------
# Static configuration (same on every node, every run)
# ---------------------------------------------------------------------------

RUSTFS_ADDRESS=":9000"
RUSTFS_CONSOLE_ENABLE=true
RUSTFS_STORAGE_CLASS_STANDARD=EC:1
RUSTFS_RUNTIME_WORKER_THREADS=64
RUSTFS_RUNTIME_MAX_BLOCKING_THREADS=4096

# Directory where RustFS writes obs JSONL span-close records.
# Used by --trace mode to locate the log file for collection.
RUSTFS_OBS_LOG_DIRECTORY=/var/logs/rustfs

# Emit span-close records only (smaller logs than "development").
RUSTFS_OBS_ENVIRONMENT=production
